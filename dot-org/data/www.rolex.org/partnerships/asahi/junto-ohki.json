                {
                  "uid": "4110ffe0-6e61-41d2-8868-2c17b95d6ece",
                  "componentName": "SimpleImage",
                  "dataSource": "{6315352D-3190-413F-8DEC-4EDBFD016DC7}",
                  "params": {},
                  "fields": {
                    "imageMobile_src": {
                      "value": "/data/media/img/asahi/junto_ohki/rolex_org_partnerships_asahi_junto_ohki_junto_ohki_square_portrait.jpg"
                    },
