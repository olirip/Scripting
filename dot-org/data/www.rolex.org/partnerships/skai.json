                  "dataSource": "{372F7884-75C2-4598-9260-FD07787A486B}",
                  "params": {},
                  "fields": {
                    "mainTitle": {
                      "value": "<b>Latest</b> episode"
                    },
                    "linkText": {
                      "value": "Read the article"
                    },
                    "rollerTitle": {
