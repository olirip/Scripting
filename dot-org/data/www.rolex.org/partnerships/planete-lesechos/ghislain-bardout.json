                {
                  "uid": "4a1df274-f75d-4a7f-9618-2bc1d91878a0",
                  "componentName": "Quote",
                  "dataSource": "{D0F5BE9D-591E-4F28-A1BF-93793B06DE34}",
                  "params": {},
                  "fields": {
                    "blackBackground": {
                      "value": false
                    },
                    "text": {
                      "value": "This story has been a great success, especially as they’re still collaborating with us today."
                    },
                    "author": {
                      "value": "Ghislain Bardout"
                    },
                    "isQuote": {
