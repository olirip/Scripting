                      "value": false
                    },
                    "poster_src": {
                      "value": "/data/media/img/rolex-mentor-protege/music/2002-2003/meetings/rmp_music_2002-2003_sir_colin_davis_joseph_caballe-domenech_posterframe_0001.jpg"
                    },
                    "source_description": {
                      "value": "Sir Colin Davis & Josep Caballé Domenech, Rolex Mentor and Protégé in Music, 2002-2003"
                    },
