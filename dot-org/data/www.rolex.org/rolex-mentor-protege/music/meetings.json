                    "mentorImage_src": {
                      "value": "/data/media/img/rolex-mentor-protege/music/2002-2003/meetings/rmp_music_2002-2003_sir_colin_davis_mentor_0001.jpg"
                    },
                    "text": {
                      "value": "Beyond his desire to succeed, it was Caballé Domenech’s passion for music that caught Sir Colin’s eye. “He’s pretty wild. One should be wild when one is young.”"
                    },
                    "author": {
                      "value": "Rolex Mentor and Protégé"
                    },
