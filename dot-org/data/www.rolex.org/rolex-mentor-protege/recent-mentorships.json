                    "backgroundPortrait_src": {
                      "value": ""
                    },
                    "ctaLabel": {
                      "value": "discover-more"
                    },
                    "ctaUrl": {
                      "value": "/rolex-mentor-protege/recent-mentorships/theatre/phyllida-lloyd-and-whitney-white"
                    },
                    "descriptionText": {
                      "value": "Drawn together by a mutual love of Shakespeare and of music, as well as an interest in telling women’s stories, Phyllida Lloyd and her protégée Whitney White found that their relationship quickly grew, developing deeper synergies as they explored the influences shaping today’s stage. The process of asking for advice soon became a two-way process between the London-based director Lloyd and Chicago-born, New York-based White.\n\n"
                    },
                    "descriptionTitle": {
                      "value": ""
                    },
                    "imageLandscape_src": {
                      "value": "/data/media/img/rolex-mentor-protege/recent-mentorships/landing-page/rolex-mentor-and-protege-2020-2022-theatre.jpg"
