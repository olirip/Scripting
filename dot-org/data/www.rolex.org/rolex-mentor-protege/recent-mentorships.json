                    },
                    "suptitle": {
                      "value": "Theatre"
                    },
                    "textColor": {
                      "value": "#000"
                    },
                    "title": {
                      "value": "PHYLLIDA LLOYD AND WHITNEY WHITE\n"
                    }
                  }
                },
                {
                  "uid": "0fb2b8b7-fe91-4eb0-b4e6-500f5782ea7d",
                  "componentName": "ParallaxedSection",
                  "dataSource": "{5566C43D-2A8A-49D1-BBC9-FE9C5E5A44CD}",
