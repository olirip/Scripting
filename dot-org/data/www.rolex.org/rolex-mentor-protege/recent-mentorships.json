                      "value": "Spike Lee and Kyle Bell\n"
                    }
                  }
                },
                {
                  "uid": "8112d342-23e5-4c62-96fd-3991f752c565",
                  "componentName": "ParallaxedSection",
                  "dataSource": "{676A9BFF-771A-4BA6-BE9D-0E7DB447D325}",
