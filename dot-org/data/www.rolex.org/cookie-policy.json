                  }
                },
                {
                  "uid": "fff493c1-36ed-5d7f-809b-ece280ff54ad",
                  "componentName": "SimpleText",
                  "dataSource": "{9D0366B1-C206-5BE2-A7A0-7F2BD0BCECDE}",
                  "params": {},
                  "fields": {
                    "noMargin": {
                      "value": false
