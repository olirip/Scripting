                    },
                    "isBold": {
                      "value": false
                    },
                    "lettrine": {
                      "value": false
                    },
                    "title": {
                      "value": "Contentsquare Cookies"
                    },
                    "titleColor": {
                      "value": ""
                    },
                    "text": {
                      "value": "<p><strong>Contentsquare</strong> is a solution which aggregates usage and frequency data so as to improve user experience. Statistics created are anonymous.</p>\n<p><em>Cookie name</em> / _cs_c<br />\n<em>Cookie purpose</em> / This cookie is used by ContentSquare to save the user consent to be tracked.<br />\n<em>Cookie expiration</em> / 13 months<br />\n<em>Storage</em> / This cookie is stored under the .rolex.org & .rolex.cn domains.</p>\n<p><em>Cookie name</em> / _cs_id<br />\n<em>Cookie purpose</em> / This cookie contains ContentSquare&rsquo;s user identifier.<br />\n<em>Cookie expiration</em> / 13 months<br />\n<em>Storage</em> / This cookie is stored under the .rolex.org & .rolex.cn domains.</p>\n<p><em>Cookie name</em> / _cs_s<br />\n<em>Cookie purpose</em> / This cookie contains the number of page views within the running session for ContentSquare Solution.<br />\n<em>Cookie expiration</em> / 30 minutes<br />\n<em>Storage</em> / This cookie is stored under the .rolex.org & .rolex.cn domains.</p>"
                    },
                    "textColor": {
                      "value": ""
                    },
                    "usText": {
                      "value": ""
                    },
                    "blackText": {
                      "value": false
                    },
                    "blackBackground": {
