                    "title": {
                      "value": "Cookies & web beacons"
                    },
                    "titleColor": {
                      "value": ""
                    },
                    "text": {
                      "value": "A cookie is a small file of letters and numbers that is stored on the hard drive of your device. Cookies are used to distinguish you from other users of our website. This helps us to understand how you are using our website."
