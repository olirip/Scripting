                    },
                    "removeLine": {
                      "value": false
                    },
                    "backgroundColor": {
                      "value": ""
                    }
                  }
                },
                {
                  "uid": "4fac3922-5d37-525a-98d1-46d695d7dfaf",
                  "componentName": "SimpleText",
                  "dataSource": "{403BDFC1-9BE2-5324-960C-3FE351B0B945}",
                  "params": {},
                  "fields": {
                    "noMargin": {
                      "value": false
                    },
                    "borderTop": {
                      "value": false
                    },
                    "isBold": {
                      "value": false
                    },
                    "lettrine": {
                      "value": false
                    },
                    "title": {
                      "value": "Performance cookies"
                    },
                    "titleColor": {
                      "value": ""
                    },
                    "text": {
                      "value": "Rolex uses performance and tracking solutions to further improve our website in order to always provide you with the best possible online experience tailored to your needs.\n"
                    },
                    "textColor": {
                      "value": ""
                    },
                    "usText": {
                      "value": ""
                    },
                    "blackText": {
                      "value": false
                    },
                    "blackBackground": {
