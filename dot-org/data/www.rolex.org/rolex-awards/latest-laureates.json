                    "backgroundPortrait_src": {
                      "value": ""
                    },
                    "ctaLabel": {
                      "value": "discover-more"
                    },
                    "ctaUrl": {
                      "value": "/rolex-awards/applied-technology/beth-koigi"
                    },
                    "descriptionText": {
                      "value": "The atmosphere contains six times more water than all of the world’s rivers combined. Kenyan entrepreneur Beth Koigi’s atmospheric water generators draw clean water from the air, helping to alleviate acute water shortages. Her generators are providing drinking water in arid regions all over the world."
                    },
                    "descriptionTitle": {
                      "value": "Extracting water from the air"
                    },
                    "imageLandscape_src": {
                      "value": "/data/media/img/rolex-awards/laureates/2023/landing-page/rolex-org-rae-2023-laureates-beth-koigi-rae23-koigi-23ed-5158.jpg"
                    },
                    "imagePortrait_src": {
                      "value": "/data/media/img/rolex-awards/laureates/2023/landing-page/rolex-org-rae-2023-laureates-beth-koigi-rae23-koigi-23ed-5158-portrait.jpg"
                    },
                    "suptitle": {
                      "value": "Kenya"
                    },
                    "textColor": {
                      "value": "#67B175"
                    },
                    "title": {
                      "value": "Beth Koigi"
                    }
                  }
                },
                {
                  "uid": "d2bc11c7-a0c7-4dda-a7c1-9a92d32cfd8f",
                  "componentName": "ParallaxedSection",
