                      "value": ""
                    },
                    "ctaLabel": {
                      "value": "discover-more"
                    },
                    "ctaUrl": {
                      "value": "/rolex-awards/environment/inza-kone"
                    },
                    "descriptionText": {
                      "value": "The Tanoé-Ehy Forest is one of West Africa’s last primary forests. Thanks to the work of Ivorian primatologist Inza Koné, it was designated a community-managed natural reserve. He is working to scale up his forest conservation model across the region to better protect its unique biodiversity."
                    },
                    "descriptionTitle": {
                      "value": "Protecting Africa’s forests"
                    },
                    "imageLandscape_src": {
                      "value": "/data/media/img/rolex-awards/laureates/2023/landing-page/rolex-org-rae-2023-laureates-inza-kone-rae23-kone-23nq-5041.jpg"
