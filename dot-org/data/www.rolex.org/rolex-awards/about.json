                      {
                        "uid": "52c3f35a-614c-599e-9f6e-9adeec66e9b7",
                        "componentName": "RollerCard",
                        "dataSource": "{83C14CCF-8BEF-5746-8C23-8783EC30F88A}",
                        "params": {},
                        "fields": {
                          "logoLabel": {
                            "value": ""
                          },
                          "articleTitle": {
                            "value": "The Rolex Awards over the decades<br><b>1990s</b>"
                          },
                          "isLink": {
                            "value": false
                          },
                          "rollerImage_src": {
                            "value": "/data/media/img/rolex-awards/about/roller_image_0003.jpg"
                          },
                          "legend": {
                            "value": ""
                          },
                          "legendRoller": {
                            "value": "The projects of the Rolex Laureates in the 1990s reflected the concerns of the day, including the growing realization that human activity was damaging the environment. Whether they were discovering new ways of monitoring ozone levels and reducing CFCs, finding innovative solutions to agricultural challenges, reforesting large areas of the planet or reducing dangerous wastes, the Award winners were helping to preserve the earth’s scarce resources."
                          },
                          "legendSlideshow": {
                            "value": ""
                          },
                          "link": {
                            "value": ""
                          },
                          "rollerImage_alt": {
