                      {
                        "uid": "b18e0296-59be-5644-bc7d-87e79d3e5c45",
                        "componentName": "RollerCard",
                        "dataSource": "{8859A9C0-92B0-502F-9175-AB6F237C1FA7}",
                        "params": {},
                        "fields": {
                          "logoLabel": {
                            "value": ""
                          },
                          "articleTitle": {
                            "value": "The Rolex Awards over the decades<br><b>1980s</b>"
                          },
                          "isLink": {
                            "value": false
                          },
                          "rollerImage_src": {
                            "value": "/data/media/img/rolex-awards/about/roller_image_0002.jpg"
                          },
                          "legend": {
                            "value": ""
                          },
                          "legendRoller": {
                            "value": "The first Rolex Awards prompted so much interest that what had been conceived of as a one-off event was extended to a new call for entries for the 1981 series. By the third (1983) and fourth (1987) series, Rolex realized it had embarked on a long-term venture, as the Awards continued to attract a flow of multidisciplinary, cross-cultural projects from around the globe. They had become an institution whose prestige had grown beyond all expectations."
                          },
                          "legendSlideshow": {
                            "value": ""
                          },
                          "link": {
