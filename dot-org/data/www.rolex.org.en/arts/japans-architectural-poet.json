                  "dataSource": "{920B54B8-8A71-5DAE-9AC0-A60BF92B8DEC}",
                  "params": {},
                  "fields": {
                    "author": {
                      "value": "by Naomi Pollock"
                    },
                    "background_alt": {
                      "value": ""
                    },
                    "image_src": {
                      "value": "/data/media/img/arts/japans-architectural-poet/desktop_0003.jpg"
                    },
