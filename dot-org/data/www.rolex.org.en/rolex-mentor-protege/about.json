                    },
                    "backgroundColor": {
                      "value": ""
                    }
                  }
                },
                {
                  "uid": "d0df5741-85b3-5733-9e44-47a4d4da2c9e",
                  "componentName": "ArticleHub",
                  "dataSource": "{C737716B-906F-532F-B0E8-9EDB8DF78042}",
                  "params": {},
                  "fields": {
                    "anchorText": {
                      "value": "Discover"
                    },
                    "backgroundLandscape_alt": {
                      "value": ""
                    },
                    "text": {
                      "value": "The Rolex mentoring programme has evolved into a global creative community that has enabled an enriching dialogue between artists of different generations, cultures and disciplines. Since 2002 nearly 1,350 people in 120 countries have been nominated for the programme. Advisors include 145 major artists and creative leaders, while 300 influential figures in the arts have nominated young artists and selected finalists. 63 of the world’s greatest artists have served as mentors."
                    },
