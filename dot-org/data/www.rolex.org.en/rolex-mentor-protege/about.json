                {
                  "uid": "63d072fc-5782-5288-bc59-e7f825dd2d39",
                  "componentName": "SimpleText",
                  "dataSource": "{12BBE5A2-320C-5DCF-99B3-437ED8919571}",
                  "params": {},
                  "fields": {
