                      "value": ""
                    },
                    "imageSrc_src": {
                      "value": "/data/media/img/rolex-mentor-protege/about/desktop_0002.jpg"
                    },
                    "legend": {
                      "value": ""
                    },
                    "imageSrc_src_NotShared": {
                      "value": ""
                    },
                    "blackBackground": {
