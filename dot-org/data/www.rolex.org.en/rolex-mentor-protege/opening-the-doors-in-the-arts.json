                    }
                  }
                },
                {
                  "uid": "e7c74edf-2c63-59ee-9a87-2647f1817e3c",
                  "componentName": "SimpleImage",
                  "dataSource": "{4845F1A2-17D1-53ED-982A-CA610A9CF949}",
                  "params": {},
