                {
                  "uid": "70cc061b-d115-5110-a61e-6bcf47a6c2b4",
                  "componentName": "SimpleText",
                  "dataSource": "{C6A8D05B-D07B-5AC0-86E5-685F56044489}",
                  "params": {},
                  "fields": {
                    "noMargin": {
