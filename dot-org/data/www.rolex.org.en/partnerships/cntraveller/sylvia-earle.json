                },
                {
                  "uid": "4110ffe0-6e61-41d2-8868-2c17b95d6ece",
                  "componentName": "SimpleImage",
                  "dataSource": "{EC607B90-0A59-4FC5-A560-6A81A1856E1D}",
                  "params": {},
                  "fields": {
                    "imageMobile_src": {
                      "value": "/data/media/img/cntraveller/saving_the_oceans/rolex_org_cn_traveller_saving_the_oceans_galapagos_675x379_portrait.jpg"
                    },
                    "link": {
