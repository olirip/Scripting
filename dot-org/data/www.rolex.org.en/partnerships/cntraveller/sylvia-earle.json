                    "date": {
                      "value": "October 2020"
                    },
                    "text": {
                      "value": "<b>Backed by Rolex, the Mission Blue initiative by Sylvia Earle is giving new life to sensitive parts of the marine world.\n</b>"
                    },
                    "videoPoster": {
                      "value": "/data/media/img/cntraveller/saving_the_oceans/rolex_org_cn_traveller_saving_the_oceans_posterframe_1920x1080.jpg"
                    },
