                {
                  "uid": "fdd2f442-09c9-457b-b317-0f1bb8e3af38",
                  "componentName": "SimpleText",
                  "dataSource": "{E7D4D16D-D16F-4E99-B061-8E3FFF8896E7}",
                  "params": {},
                  "fields": {
                    "noMargin": {
                      "value": true
                    },
                    "borderTop": {
