                  }
                },
                {
                  "uid": "a9cd4c2d-d49b-4131-ba01-7cb5f066a03a",
                  "componentName": "HubBackgroundQuote",
                  "dataSource": "{15458D13-252E-47F1-808E-59C37ECED7B0}",
