                    }
                  }
                },
                {
                  "uid": "1360bcbc-a7a1-4810-9fed-db2d3c6e1a35",
                  "componentName": "SimpleImage",
                  "dataSource": "{C9F536F9-A2F1-405E-A019-5CDAFC2580E7}",
                  "params": {},
                  "fields": {
                    "imageMobile_src": {
                      "value": "/data/media/img/ogsociety/sylvia-earle/rolex_org_ocean_geographic_square2_portrait.jpg"
                    },
                    "link": {
