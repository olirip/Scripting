                {
                  "uid": "81432fb3-da37-4c1f-981f-45e5041d6806",
                  "componentName": "SimpleText",
                  "dataSource": "{E46ACEBD-9112-4323-A82E-E5DD0F8EC184}",
                  "params": {},
                  "fields": {
                    "noMargin": {
                      "value": true
                    },
                    "borderTop": {
