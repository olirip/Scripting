                {
                  "uid": "fbf78c01-096e-4ac4-a4bc-a13281f4754a",
                  "componentName": "SimpleText",
                  "dataSource": "{F27402CE-AEE8-41C1-8CE1-701AF7D751BB}",
                  "params": {},
                  "fields": {
                    "noMargin": {
                      "value": false
