                },
                {
                  "uid": "fbf78c01-096e-4ac4-a4bc-a13281f4754a",
                  "componentName": "SimpleText",
                  "dataSource": "{28E9975B-A33C-48AA-A551-54B2FB862DED}",
                  "params": {},
                  "fields": {
                    "noMargin": {
                      "value": false
